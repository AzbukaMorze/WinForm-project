{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch ImageContrastApp",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build ImageContrastApp",
      "program": "${workspaceFolder}/ImageContrastApp/bin/Debug/net10.0-windows/ImageContrastApp.dll",
      "cwd": "${workspaceFolder}/ImageContrastApp",
      "stopAtEntry": false,
      "console": "internalConsole"
    }
  ]
}
